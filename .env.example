# ===========================================
# Nextcloud + PostgreSQL (pgvector) Configuration
# Nextcloud + PostgreSQL (pgvector) 設定檔
# ===========================================
# Copy this file to .env and fill in the values
# 複製此檔案為 .env 並填入數值
# ===========================================

# -----------------------
# PostgreSQL Database
# PostgreSQL 資料庫
# -----------------------
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
# IMPORTANT: Change this to a secure password!
# 重要：請修改為安全的密碼！
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# -----------------------
# Nextcloud Admin
# Nextcloud 管理員
# -----------------------
NEXTCLOUD_ADMIN_USER=admin
# IMPORTANT: Change this to a secure password!
# 重要：請修改為安全的密碼！
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# -----------------------
# Nextcloud Settings
# Nextcloud 設定
# -----------------------
# Trusted domains (space-separated)
# 信任的網域（空格分隔）
# Example: localhost your-domain.com 192.168.1.100
NEXTCLOUD_TRUSTED_DOMAINS=localhost

# Port exposed on host
# 主機開放的連接埠
NEXTCLOUD_PORT=18080

# -----------------------
# Cloudflare Tunnel Settings
# Cloudflare Tunnel 設定
# -----------------------
# Protocol for generated URLs (https when behind Cloudflare)
# 產生 URL 的協定（使用 Cloudflare 時設為 https）
OVERWRITEPROTOCOL=https

# Full URL for CLI operations (optional)
# CLI 操作的完整 URL（選填）
# Example: https://cloud.your-domain.com
OVERWRITECLIURL=

# Trusted proxies for Cloudflare (optional)
# Cloudflare 的信任代理（選填）
# Example: 172.16.0.0/12 for Docker network
TRUSTED_PROXIES=
